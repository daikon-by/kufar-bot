BOT_TOKEN=
ADMIN_IDS=123456789
ADMIN_USERNAME=dankovvv
# Образ для продакшена (docker-compose.prod.yml / scripts/update.sh)
KUFAR_BOT_IMAGE=ghcr.io/daikon-by/kufar-bot:latest
DATABASE_URL=sqlite+aiosqlite:///./data/kufar_bot.db
KUFAR_IMPERSONATE=chrome
KUFAR_FETCH_DESCRIPTION=true
KUFAR_DESCRIPTION_MAX_CHARS=600
KUFAR_REQUEST_DELAY_SEC=0.4
KUFAR_USE_THUMBNAIL=true
POLL_MAX_PAGES=3
POLL_WATERMARK_MAX_PAGES=100
POLL_FIRST_RUN_HOURS=24
POLL_DIGEST_THRESHOLD=250
POLL_MAX_SEND_PER_RUN=0
TELEGRAM_SEND_DELAY_SEC=1.0
LOG_LEVEL=INFO
# DEBUG — подробные HTTP-запросы к Kufar
